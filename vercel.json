{
  "redirects": [
    {
      "source": "/sarees/bishnupur",
      "destination": "/sarees/kantha-stitch",
      "permanent": true
    },
    {
      "source": "/sarees/kantha",
      "destination": "/sarees/kantha-stitch",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/" }
  ],
  "headers": [
    {
      "source": "/sarees/kantha-stitch",
      "headers": [
        { "key": "X-Robots-Tag", "value": "index, follow" }
      ]
    }
  ]
}